# --- SICUREZZA (NON CANCELLARE MAI QUESTE RIGHE) ---
.env
osint_session
osint_session.session

# --- Log e file temporanei ---
tracker_log.txt
*.log

# --- Python spazzatura (file compilati) ---
__pycache__/
*.pyc

# Aggiungi le regole al file .gitignore
Add-Content .gitignore "`nscripts/service_account.json"
Add-Content .gitignore "`n.env"
Add-Content .gitignore "`n**/*.session"

